<%- include('adheader') %>
<section class="content-main">
    <div class="content-header">
        <div>
            <h2 class="content-title card-title">Order List</h2>
            <p>Overview of all orders and their status.</p>
        </div>
    </div>

    <div class="card mb-4">
        <header class="card-header">
            <div class="row gx-3">
            </div>
        </header>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#Order ID</th>
                            <th scope="col">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Total</th>
                            <th scope="col">Status</th>
                            <th scope="col">Date</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order => { %>
                            <tr>
                                <td>#<%= order._id.toString().slice(-5).toUpperCase() %></td> <!-- Show last 5 characters of the order ID -->
                                <td><%= order.user ? order.user.name : 'No User Data' %></td>
                                <td><%= order.user ? order.user.email : 'No User Data' %></td>
                                <td>₹<%= order.totalPrice.toFixed(2) %></td>
                                <td>
                                    <span class="badge <%= order.status === 'Pending' ? 'alert-warning' : 'alert-success' %>">
                                        <%= order.status %>
                                    </span>
                                </td>
                                <td><%= new Date(order.orderDate).toLocaleDateString() %></td>
                                <td class="text-end">
                                    <a href="orders/<%= order._id %>" class="btn btn-md rounded font-sm">Details</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
<%- include('adfooter') %>
