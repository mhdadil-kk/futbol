<%- include('adheader') %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css">

    <style>
        .notification-dot {
            position: absolute;
            top: 0;
            right: 0;
            width: 8px;
            /* Adjust size as needed */
            height: 8px;
            /* Adjust size as needed */
            background-color: red;
            /* Change color if needed */
            border-radius: 50%;
            /* Make it round */
            box-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
            /* Optional shadow for better visibility */
        }
    </style>

    <section class="content-main">
        <div class="content-header">
            <div>
                <h2 class="content-title card-title">Order detail</h2>
                <p>Details for Order ID: #<%= order._id.toString().slice(-5).toUpperCase() %>
                </p>
            </div>
        </div>

        <div class="card">
            <header class="card-header">
                <div class="row align-items-center">
                    <div class="col-lg-6 col-md-6 mb-lg-0 mb-15">
                        <span>
                            <i class="material-icons md-calendar_today"></i>
                            <b>
                                <%= new Date(order.orderDate).toLocaleString() %>
                            </b>
                        </span>
                        <br />
                        <small class="text-muted">Order ID: #<%= order._id.toString().slice(-5).toUpperCase() %>
                        </small>
                    </div>
                    <div class="col-lg-6 col-md-6 ms-auto text-md-end">
                        <form id="updateOrderForm" action="/admin/update-order/<%= order._id %>" method="POST">
                            <select name="status" class="form-select d-inline-block mb-lg-0 mr-5 mw-200">
                                <option value="Pending" <%=order.status==='Pending' ? 'selected' : '' %>>Pending
                                </option>
                                <option value="Processing" <%=order.status==='Processing' ? 'selected' : '' %>
                                    >Processing</option>
                                <option value="Shipped" <%=order.status==='Shipped' ? 'selected' : '' %>>Shipped
                                </option>
                                <option value="Delivered" <%=order.status==='Delivered' ? 'selected' : '' %>>Delivered
                                </option>
                                <option value="Cancelled" <%=order.status==='Cancelled' ? 'selected' : '' %>>Cancelled
                                </option>
                            </select>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </form>
                    </div>
                </div>
            </header>
            <!-- card-header end// -->

            <div class="card-body">
                <div class="row mb-50 mt-20 order-info-wrap">
                    <div class="col-md-4">
                        <article class="icontext align-items-start">
                            <span class="icon icon-sm rounded-circle bg-primary-light">
                                <i class="text-primary material-icons md-person"></i>
                            </span>
                            <div class="text">
                                <h6 class="mb-1">Customer</h6>
                                <p class="mb-1">
                                    <%= order.user.name %> <br />
                                        <%= order.user.email %> <br />
                                            <%= order.user.mobile %>
                                </p>
                                <a href="#">View profile</a>
                            </div>
                        </article>
                    </div>
                    <!-- col// -->

                    <div class="col-md-4">
                        <article class="icontext align-items-start">
                            <span class="icon icon-sm rounded-circle bg-primary-light">
                                <i class="text-primary material-icons md-local_shipping"></i>
                            </span>
                            <div class="text">
                                <h6 class="mb-1">Order info</h6>
                                <p class="mb-1">
                                    Shipping: <%= order.shippingMethod || 'N/A' %> <br />
                                        Pay method: <%= order.paymentMethod %> <br />
                                            Status: <%= order.status %>
                                </p>
                                <a href="#">Download info</a>
                            </div>
                        </article>
                    </div>
                    <!-- col// -->

                    <div class="col-md-4">
                        <article class="icontext align-items-start">
                            <span class="icon icon-sm rounded-circle bg-primary-light">
                                <i class="text-primary material-icons md-place"></i>
                            </span>
                            <div class="text">
                                <h6 class="mb-1">Deliver to</h6>
                                <p class="mb-1">
                                    <% if (order.deliveryAddress) { %>
                                        City: <%= order.deliveryAddress.streetAddress || 'N/A' %> <br />
                                            State: <%= order.deliveryAddress.state || 'N/A' %> <br />
                                                District: <%= order.deliveryAddress.district || 'N/A' %> <br />
                                                    PinCode: <%= order.deliveryAddress.pinCode || 'N/A' %> <br />
                                                        Country: <%= order.deliveryAddress.country || 'N/A' %> <br />
                                                            <% } else { %>
                                                                No delivery address provided
                                                                <% } %>
                                </p>
                                <a href="#">View profile</a>
                            </div>
                        </article>
                    </div>
                    <!-- col// -->
                </div>
                <!-- row // -->

                <!-- Table for order products -->
                <div class="row">
                    <div class="col-lg-12"> <!-- Changed col-lg-7 to col-lg-12 for full width -->
                        <div class="table-responsive">
                            <table class="table table-bordered w-100"> <!-- Added w-100 class for full width -->
                                <thead class="thead-light">
                                    <tr>
                                        <th width="40%">Product</th>
                                        <th width="20%">Unit Price</th>
                                        <th width="20%">Quantity</th>
                                        <th width="10%">Return Status</th>
                                        <th width="10%">Return Reason</th>
                                        <th width="10%" class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (order.products && order.products.length> 0) { %>
                                        <% order.products.forEach(item=> { %>
                                            <tr>
                                                <td>
                                                    <a class="itemside d-flex align-items-center" href="#">
                                                        <div class="left">
                                                            <img src="/uploads/<%= item.product.images[0] %>" width="40"
                                                                height="40" class="img-xs" alt="Item" />
                                                        </div>
                                                        <div class="info ms-2">
                                                            <%= item.product ? item.product.name : 'No Product Name' %>
                                                        </div>
                                                    </a>
                                                </td>
                                                <td>₹<%= item.price.toFixed(2) %>
                                                </td>
                                                <td>
                                                    <%= item.quantity %>
                                                </td>

                                                <!-- Return Status and Actions -->
                                                <td style="padding-right: 30px; padding-bottom: 15px;">
                                                    <% if (returnedProductMap[item.product._id]) { %>
                                                        <!-- Flex container for status and three-dot menu -->
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <!-- Status text -->
                                                            <span class="badge 
                                                                <%= returnedProductMap[item.product._id].status === 'requested' ? 'bg-warning' : '' %>
                                                                <%= returnedProductMap[item.product._id].status === 'approved' ? 'bg-info' : '' %>
                                                                <%= returnedProductMap[item.product._id].status === 'rejected' ? 'bg-danger' : '' %>
                                                                <%= returnedProductMap[item.product._id].status === 'returned' ? 'bg-success' : '' %>">
                                                                <%= returnedProductMap[item.product._id].status %>
                                                            </span>
                                                
                                                            <!-- Dropdown for both "requested" and "approved" statuses -->
                                                            <% if (returnedProductMap[item.product._id].status === 'requested' || returnedProductMap[item.product._id].status === 'approved') { %>
                                                                <div class="dropdown" style="position: relative;">
                                                                    <button class="btn btn-link dropdown-toggle-no-arrow p-0" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                                                        <i class="bi bi-three-dots-vertical"></i>
                                                                        <span class="notification-dot"></span> <!-- Notification dot -->
                                                                    </button>
                                                                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                                                                        <% if (returnedProductMap[item.product._id].status === 'requested') { %>
                                                                            <li>
                                                                                <!-- Green for Accept -->
                                                                                <a class="dropdown-item text-success" onclick="returnReq('<%= item.product._id %>', 'Accept', '<%= order._id %>')">
                                                                                    Accept
                                                                                </a>
                                                                            </li>
                                                                            <li>
                                                                                <!-- Red for Reject -->
                                                                                <a class="dropdown-item text-danger" onclick="returnReq('<%= item.product._id %>', 'Reject', '<%= order._id %>')">
                                                                                    Reject
                                                                                </a>
                                                                            </li>
                                                                        <% } else if (returnedProductMap[item.product._id].status === 'approved') { %>
                                                                            <li>
                                                                                <!-- Blue for Returned -->
                                                                                <a class="dropdown-item text-primary" onclick="returnReq('<%= item.product._id %>', 'Returned', '<%= order._id %>')">
                                                                                    Returned
                                                                                </a>
                                                                            </li>
                                                                        <% } %>
                                                                    </ul>
                                                                    
                                                                </div>
                                                            <% } %>
                                                        </div>
                                                    <% } else { %>
                                                        <span>No return requested</span>
                                                    <% } %>
                                                </td>
                                                


                                                <td style="padding-right: 30px;"> <!-- Add padding for spacing -->
                                                    <% if (returnedProductMap[item.product._id] &&
                                                        returnedProductMap[item.product._id].reason) { %>
                                                        <%= returnedProductMap[item.product._id].reason %>
                                                            <% } else { %>
                                                                N/A
                                                                <% } %>
                                                </td>

                                                <td class="text-end" style="padding-left: 30px;">
                                                    <!-- Add padding for spacing -->
                                                    ₹<%= (item.price * item.quantity).toFixed(2) %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="text-center">No items found</td>
                                                    </tr>
                                                    <% } %>
                                                        <!-- Summary Row -->
                                                        <tr>
                                                            <td colspan="5" class="text-end"><strong>Subtotal:</strong>
                                                            </td>
                                                            <td class="text-end">₹<%= order.totalPrice.toFixed(2) %>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td colspan="5" class="text-end"><strong>Grand
                                                                    Total:</strong></td>
                                                            <td class="text-end"><b class="h5">₹<%=
                                                                        (order.totalPrice).toFixed(2) %></b></td>
                                                        </tr>
                                                        <tr>
                                                            <td colspan="5" class="text-end"><strong>Status:</strong>
                                                            </td>
                                                            <td class="text-end">
                                                                <span
                                                                    class="badge rounded-pill <%= order.paymentStatus === 'Paid' ? 'bg-success text-white' : 'bg-warning text-dark' %>">
                                                                    <%= order.paymentStatus %>
                                                                </span>
                                                            </td>
                                                        </tr>
                                </tbody>
                            </table>


                        </div>
                    </div>
                </div>
            </div>
            <!-- card-body end// -->
        </div>
        <!-- card end// -->
    </section>
    <!-- content-main end// -->

    <%- include('adfooter') %>

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.getElementById('updateOrderForm').addEventListener('submit', function (event) {
                event.preventDefault(); // Prevent the default form submission
                Swal.fire({
                    title: 'Are you sure?',
                    text: "Do you want to update the order status?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, update it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        this.submit(); // Submit the form if confirmed
                    }
                });
            });


            function returnReq(productId, action, orderId) {
                // Confirmation alert using SweetAlert2
                Swal.fire({
                    title: "Are you sure?",
                    text: `Do you really want to ${action.toLowerCase()} this return request?`,
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#3085d6",
                    cancelButtonColor: "#d33",
                    confirmButtonText: "Yes, proceed!",
                    cancelButtonText: "No, cancel!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Create an object to store the data to send
                        const requestData = {
                            productId: productId,
                            action: action,
                            orderId: orderId
                        };

                        // Send the request to your server
                        fetch('/admin/api/return-request', {
                            method: 'POST', // Change this according to your server API
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify(requestData)
                        })
                            .then(response => response.json())
                            .then(data => {
                                // Handle the response from the server
                                if (data.success) {
                                    Swal.fire("Success!", `Return request ${action}ed successfully!`, "success").then(() => {
                                        // Set a timeout to reload the page after showing the success modal
                                        setTimeout(() => {
                                            location.reload(); // Reloads the page to reflect changes
                                        }, 500); // 1500ms = 1.5 seconds delay
                                    });
                                }
                                else {
                                    Swal.fire("Error!", `Failed to ${action.toLowerCase()} return request: ${data.message}`, "error");
                                }
                            })
                            .catch(error => {
                                console.error('Error:', error);
                                Swal.fire("Error!", "An error occurred while processing your request.", "error");
                            });
                    } else {
                        Swal.fire("Cancelled", "Your action has been cancelled.", "info");
                    }
                });
            }

        </script>